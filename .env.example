# Three Kingdoms Arena — Environment Variables
# Copy this file to .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────
# Public URL of the server (used in instruction templates, API docs)
ARENA_SERVER_URL=http://localhost:8000

# Frontend URL (for CORS, may differ from SERVER_URL in local dev)
ARENA_FRONTEND_URL=http://localhost:5173

# Comma-separated CORS origins, or "*" to allow all (disables credentials)
ARENA_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Environment: development | production
ENVIRONMENT=development

# Rate limit (requests/minute per IP)
ARENA_RATE_LIMIT=5000/minute

# Restrict one faction per IP (default: false). Set to true to prevent multi-accounting.
# ENFORCE_ONE_FACTION_PER_IP=false

# ── Tick / Game Timing ──────────────────────────────────────────
# Tick submission window (seconds), default 15
# TICK_INTERVAL_SEC=15
# Tick force-advance timeout (seconds), default 20
# TICK_TIMEOUT_SEC=20

# ── Economy ─────────────────────────────────────────────────────
# Grain awarded when capturing a city (default 200)
# OCCUPATION_REWARD_GRAIN=200
# Economic catch-up for factions behind in city count (default false)
# ECONOMIC_CATCHUP_ENABLED=false
# ECONOMIC_CATCHUP_PER_CITY_BEHIND=0.10

# ── Admin ───────────────────────────────────────────────────────
# Change this to a strong random string in production!
ADMIN_TOKEN=change-me-in-production

# ── Managed AI ──────────────────────────────────────────────────
# When enabled, empty faction slots are filled by rule-based managed AI agents.
# Disable to require all-human lobbies.
# ENABLE_MANAGED_AI=true
# Managed AI aggression: 0.0 = purely defensive, 1.0 = very aggressive.
# MANAGED_AI_AGGRESSION=0.3

# ── LLM API Keys (optional, for managed AI agents) ──────────────
# OPENAI_API_KEY=sk-your-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# DEEPSEEK_API_KEY=sk-your-key

# ── LLM Provider (optional) ─────────────────────────────────────
# DEFAULT_LLM_PROVIDER=mock
# DEFAULT_LLM_MODEL=
