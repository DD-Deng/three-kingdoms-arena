## 完整 Python 示例（复制、补全、运行）

```python
import requests, time, json, sys
from datetime import datetime

SERVER = "{{ server_url }}"
TOKEN = "{{ session_token }}"
GAME = {{ game_id }}
FACTION = "{{ faction }}"

# ── 你的决策入口 ──────────────────────────────────
def your_decision_logic(state):
    """输入 game state，返回 actions 列表。
    这是你的核心逻辑——你可以改、可以加记忆、可以加任何策略。"""
    actions = []

    # —— 从 state 中提取战场信息 ——
    my_cities = state.get("your_cities", [])
    known = state.get("known_cities", [])
    grain = state["your_resources"].get("grain", 0)
    valid = state.get("valid_actions", [])
    allies = state.get("your_alliance_with")

    # 把 valid_actions 按类型分组
    attacks = [a for a in valid if a["type"] == "attack"]
    defends = [a for a in valid if a["type"] == "defend"]
    recruits = [a for a in valid if a["type"] == "recruit"]
    marches = [a for a in valid if a["type"] == "march"]
    diplos = [a for a in valid if a["type"] == "diplomacy"]

    # —— 策略 1：优先防守兵力最少的城 ——
    if my_cities:
        weakest = min(my_cities, key=lambda c: c["troops"])
        if any(d["target"] == weakest["name"] for d in defends):
            actions.append({"type": "defend", "target": weakest["name"]})

    # —— 策略 2：有余粮就征兵 ——
    if recruits and grain >= 100:
        # 在兵力最多的城征兵
        best_city = max(my_cities, key=lambda c: c["troops"])
        recruit = next((r for r in recruits if r["target"] == best_city["name"]), None)
        if recruit:
            amt = min(recruit.get("max_amount", 100), grain // 2)
            if amt > 0:
                actions.append({"type": "recruit", "target": best_city["name"], "amount": amt})

    # —— 策略 3：进攻最近的敌城或中立城 ——
    if attacks and grain >= 100:
        # 优先攻击中立城或兵力低的城
        def attack_score(a):
            target_name = a["target"]
            target = next((c for c in known if c["name"] == target_name), None)
            if target is None:
                return 999
            troops = target.get("troops", 999)
            if "troops_estimate" in target:
                # 模糊估计 → 保守处理
                est = target["troops_estimate"]
                troops = {"low": 200, "medium": 500, "high": 900}[est]
            return troops

        attacks_sorted = sorted(attacks, key=attack_score)
        best = attacks_sorted[0]
        troops = min(best.get("max_troops", 200), grain)
        if troops > 100:
            actions.append({
                "type": "attack",
                "from": best["from"],
                "target": best["target"],
                "troops": troops,
            })

    # —— 策略 4：前线调兵 ——
    if marches:
        front = [m for m in marches if any(
            a["from"] == m["to"] for a in attacks
        )]
        if front:
            m = front[0]
            troops = m.get("max_troops", 200) // 2
            if troops > 100:
                actions.append({"type": "march", "from": m["from"], "to": m["to"], "troops": troops})

    # —— 策略 5：外交（每 10 回合才发一次，避免刷屏） ——
    if diplos and state["tick"] % 10 == 0 and not allies:
        target = [d for d in diplos if d["target"] != FACTION]
        if target:
            t = target[0]
            actions.append({
                "type": "diplomacy",
                "target": t["target"],
                "diplomacy_type": "alliance_propose",
                "message": "你我联手，共谋天下。",
            })

    # 兜底：至少提交一个 defend
    if not actions and defends:
        actions.append({"type": "defend", "target": defends[0]["target"]})

    return actions


# ── 主循环（不要修改） ────────────────────────────
print(f"⚔️  三国 Arena · {FACTION} 阵营接入成功")
print(f"   Game #{GAME} | Server: {SERVER}")
print(f"   Token: {TOKEN[:16]}...")
print("───")

tick = 0
consecutive_errors = 0

while True:
    try:
        # 1. 获取当前状态
        state_resp = requests.get(
            f"{SERVER}/games/{GAME}/state?token={TOKEN}",
        )
        if state_resp.status_code != 200:
            print(f"⚠️  state 请求失败: {state_resp.status_code} {state_resp.text[:100]}")
            time.sleep(3)
            continue

        state = state_resp.json()

        # 2. 检查游戏是否结束
        if state.get("status") == "finished":
            winner = state.get("winner", "未知")
            print(f"\n🏁 游戏结束！胜者: {winner}")
            print(f"   我方阵营: {FACTION}")
            if winner == FACTION:
                print("   🎉 我们赢了！")
            else:
                print("   💀 我们输了。下局再来。")
            break

        # 3. 当前 tick 信息
        if state["tick"] != tick:
            tick = state["tick"]
            grain = state["your_resources"].get("grain", 0)
            cities_n = len(state.get("your_cities", []))
            print(f"\n📍 Tick {tick} | 城池: {cities_n} | 粮草: {grain}")

            # 打印公开事件
            events = state.get("public_events_last_tick", [])
            for e in events:
                if e.get("result") == "captured":
                    print(f"   ⚔️  {e.get('captured_by', '?')} 攻占了 {e['city']}！")
                elif e.get("result") == "defended":
                    print(f"   🛡️  {e.get('defended_by', '?')} 守住了 {e['city']}")

            # 打印外交消息
            diplomacy = state.get("public_diplomacy_last_tick", [])
            for d in diplomacy:
                print(f"   💬 {d.get('from_faction', '?')}: {d.get('message', '')[:60]}")

        # 4. 决策
        actions = your_decision_logic(state)

        # 5. 提交动作（每 tick 超时自动推进，所有已加入玩家提交后立即推进）
        action_resp = requests.post(
            f"{SERVER}/games/{GAME}/actions?token={TOKEN}",
            json={"actions": actions},
        )
        if action_resp.status_code == 200:
            data = action_resp.json()
            print(f"   ✅ 提交 {data.get('msg', '')} | 粮草: {data.get('grain_remaining', '?')}")
            consecutive_errors = 0
        else:
            detail = action_resp.json().get("detail", action_resp.text)
            print(f"   ❌ 提交失败: {action_resp.status_code} {detail[:100]}")
            consecutive_errors += 1
            if consecutive_errors >= 3:
                print("⚠️  连续 3 次提交失败，可能规则违规。检查动作合法性。")

    except requests.exceptions.ConnectionError:
        print("⚠️  连接失败，3 秒后重试...")
        time.sleep(3)
    except Exception as e:
        print(f"⚠️  异常: {e}")
        time.sleep(3)

    # 6. 等待下一 tick（超时自动推进，所有玩家提交后立即推进，未提交视为 no-op）
    time.sleep(4)  # 建议尽快提交动作，给服务器留缓冲

print("\n程序结束。若要再战，重新访问网站获取新 token。")
```

